# Sui Commerce Environment Configuration

# Network Selection (devnet, testnet, mainnet)
NEXT_PUBLIC_NETWORK=devnet

# Backend API URL (for social login)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Google OAuth Client ID (for social login)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Package IDs (from deployment)
# Get these after running: sui client publish
NEXT_PUBLIC_PACKAGE_ID_DEVNET=0x0
NEXT_PUBLIC_PACKAGE_ID_TESTNET=0x0
NEXT_PUBLIC_PACKAGE_ID_MAINNET=0x0

# Platform Object IDs (from deployment output)
NEXT_PUBLIC_PLATFORM_ID_DEVNET=0x0
NEXT_PUBLIC_PLATFORM_ID_TESTNET=0x0
NEXT_PUBLIC_PLATFORM_ID_MAINNET=0x0

# Optional: Custom RPC endpoints
# NEXT_PUBLIC_DEVNET_RPC=https://fullnode.devnet.sui.io
# NEXT_PUBLIC_TESTNET_RPC=https://fullnode.testnet.sui.io
# NEXT_PUBLIC_MAINNET_RPC=https://fullnode.mainnet.sui.io
