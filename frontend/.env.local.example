# Sui Shop Web Frontend - Environment Variables
# Copy this file to .env.local and fill in your values

# ==================== Backend API ====================

# Backend API URL (for social login)
NEXT_PUBLIC_API_URL=http://localhost:3001

# In production, change to your deployed backend:
# NEXT_PUBLIC_API_URL=https://api.suishop.com

# ==================== Social Login ====================

# Google OAuth Client ID
# Get from: https://console.cloud.google.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Example:
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=123456789-abcdefghijklmnop.apps.googleusercontent.com

# ==================== Sui Network ====================

# Sui network to connect to
NEXT_PUBLIC_SUI_NETWORK=testnet
#NEXT_PUBLIC_NETWORK=testnet
NEXT_PUBLIC_MARKETPLACE_PACKAGE=0x1dcd47cca0b397d4734cb90af864af9f0d368c0ea9d424de14c0a85e4598067e  # Your Package ID
NEXT_PUBLIC_MARKETPLACE_OBJECT=0x000f85e251c05ce77e1e4e07960d11d3163c53e584a9f688f153555045948238   # Your Marketplace Object ID
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Options: testnet, mainnet, devnet, localnet
# For production, use: mainnet

# ==================== Optional ====================

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry Error Tracking (optional)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# ==================== Setup Instructions ====================

# 1. Copy this file:
#    cp .env.local.example .env.local

# 2. Get Google Client ID:
#    - Go to https://console.cloud.google.com
#    - Create new project "Sui Shop"
#    - Enable Google+ API
#    - Create OAuth 2.0 Client ID (Web application)
#    - Add authorized origin: http://localhost:3000
#    - Copy Client ID and paste above

# 3. Start backend:
#    cd ../backend
#    npm run dev

# 4. Start frontend:
#    npm run dev

# ==================== Notes ====================

# - NEXT_PUBLIC_ prefix makes variables available to browser
# - Never commit .env.local to git
# - Backend must be running for social login to work
# - Extension-only mode works without backend
