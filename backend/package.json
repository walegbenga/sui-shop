{
  "name": "sui-shop-backend",
  "version": "1.0.0",
  "description": "Scalable backend for Sui Shop marketplace",
  "main": "dist/api/server.js",
  "scripts": {
    "dev:api": "nodemon --exec ts-node src/api/server.ts",
    "dev:indexer": "nodemon --exec ts-node src/indexer/index.ts",
    "build": "tsc",
    "start:api": "node dist/api/server.js",
    "start:indexer": "node dist/indexer/index.js",
    "seed": "ts-node scripts/seed-products.ts",
    "start": "npm run build && node dist/api/server.js",
    "indexer": "npm run build && node dist/indexer/index.js"
  },
  "keywords": [
    "sui",
    "blockchain",
    "marketplace"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mysten/sui": "^1.14.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "pinata-web3": "^0.5.4",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "@types/redis": "^4.0.10",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}